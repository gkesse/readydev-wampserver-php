{% macro showMenu(menuList, parentIndex) %}
    {% set menuListI = menuList.getMenuListByParentIndex(parentIndex) %}
    {% for menuI in menuListI.getMenuList() %}
        {% set menuListJ = menuList.getMenuListByParentIndex(menuI.index) %}
        {% if parentIndex == 0 %}
            <div class='Block26'>
                <button class='Block29'>{{ menuI.title }}</button>
                <div class='Block27'>
                    {{ _self.showMenu(menuList, menuI.index) }}
                </div>
            </div>
        {% elseif menuListJ.isEmpty() == false %}
            <div class='Block31'>
                <div class='Block28'>{{ menuI.title }} <i class='Block25 fa fa-caret-down'></i></div>
                <div class='Block30'>
                    {{ _self.showMenu(menuList, menuI.index) }}
                </div>
            </div>
        {% else %}
            <div class='Block32' onclick='callBackend("{{ menuI.module }}", "{{ menuI.method }}", this, "{{ menuI.data }}")'>{{ menuI.title }}</div>
        {% endif %}
    {% endfor %}
{% endmacro %}

{% macro showAction(menuList, parentIndex) %}
    {% set menuListI = menuList.getMenuListByParentIndex(parentIndex) %}
    {% for menuI in menuListI.getMenuList() %}
        {% set menuListJ = menuList.getMenuListByParentIndex(menuI.index) %}
        {% if menuListJ.isEmpty() == true %}
            <div class='Block20' onclick='callBackend("{{ menuI.module }}", "{{ menuI.method }}", this, "{{ menuI.data }}")'>{{ menuI.title }}</div>
        {% else %}
            <div class='Block21'>
                <div class='Block20'>{{ menuI.title }} <i class='Block25 fa fa-caret-down'></i></div>
                <div class='Block22'>
                    {{ _self.showAction(menuList, menuI.index) }}
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endmacro %}
